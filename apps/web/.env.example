# Ключ шифрования OAuth-токенов (обязательно). Минимум 16 символов, лучше 32+.
# Используйте СЛУЧАЙНОЕ значение, напр.: openssl rand -base64 32
# Токен доступа сотрудника содержит его Kaiten API-токен, зашифрованный этим ключом
# через JWE (A256GCM). Без этого ключа токены нельзя будет ни выдать, ни проверить.
AUTH_SECRET=change-me-to-a-long-random-string

# Опционально: единый Kaiten URL для всей организации.
# Если задан, форма авторизации не будет спрашивать URL у сотрудника —
# он вводит только свой персональный API-токен.
# KAITEN_API_URL=https://your-domain.kaiten.ru/api/latest

# Опционально: список разрешённых redirect_uri (через запятую) для OAuth.
# По умолчанию разрешены колбэки Claude (claude.ai/claude.com) и loopback
# (localhost/127.0.0.1 — для Claude Code). Задайте, чтобы ограничить жёстче.
# ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
