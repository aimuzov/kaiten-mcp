{
	"name": "@aimuzov/kaiten-mcp",
	"version": "0.1.0",
	"description": "MCP server for Kaiten — manage spaces, boards, cards, comments, checklists, time tracking and day planning from any MCP client (stdio).",
	"keywords": [
		"kaiten",
		"mcp",
		"model-context-protocol",
		"mcp-server",
		"claude",
		"claude-desktop",
		"claude-code",
		"cowork",
		"ai",
		"llm",
		"stdio",
		"kanban",
		"project-management",
		"task-management"
	],
	"homepage": "https://github.com/aimuzov/kaiten-mcp#readme",
	"bugs": {
		"url": "https://github.com/aimuzov/kaiten-mcp/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aimuzov/kaiten-mcp.git",
		"directory": "packages/cli"
	},
	"license": "MIT",
	"author": "Aleksey Imuzov",
	"type": "module",
	"bin": {
		"kaiten-mcp": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"README.ru.md",
		".env.example",
		"LICENSE"
	],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p scripts/tsconfig.json --noEmit",
		"start": "node dist/index.js",
		"smoke": "node --import tsx scripts/smoke.ts",
		"test:elicit": "node --import tsx scripts/elicit-test.ts"
	},
	"dependencies": {
		"@aimuzov/kaiten-mcp-core": "^0.1.0",
		"@modelcontextprotocol/sdk": "1.29.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/node": "25.9.3",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	}
}
