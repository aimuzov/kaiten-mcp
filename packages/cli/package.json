{
  "name": "kaiten-mcp",
  "version": "0.1.0",
  "description": "Kaiten MCP server (stdio) for local use in Cowork/Claude.",
  "type": "module",
  "bin": { "kaiten-mcp": "dist/index.js" },
  "files": ["dist", "README.md", ".env.example"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "smoke": "node --import tsx scripts/smoke.ts",
    "test:elicit": "node --import tsx scripts/elicit-test.ts"
  },
  "dependencies": {
    "@kaiten-mcp/core": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": { "@types/node": "^22.0.0", "tsx": "^4.19.0", "typescript": "^5.6.0" }
}
