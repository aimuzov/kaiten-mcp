# Конфигурация kaiten-mcp (stdio-сервер)

# Базовый URL Kaiten API. Можно указать без /api/latest — добавится автоматически.
# Пример: https://your-domain.kaiten.ru
KAITEN_API_URL=https://your-domain.kaiten.ru/api/latest

# Персональный API-токен Kaiten.
# Если не задан, сервер запросит его через механизм MCP elicitation при первом обращении.
# KAITEN_API_TOKEN=your-token-here

# Необязательные настройки:

# ID пространства по умолчанию для list_boards без явного space_id
# KAITEN_DEFAULT_SPACE_ID=

# Таймаут запросов к Kaiten, мс (по умолчанию 30000)
# KAITEN_REQUEST_TIMEOUT_MS=30000

# Максимальное число одновременных запросов, 1–20 (по умолчанию 5)
# KAITEN_MAX_CONCURRENT_REQUESTS=5

# Уровень логирования: error | warn | info | debug (по умолчанию info)
# KAITEN_LOG_LEVEL=info

# Путь к файлу лога (по умолчанию только stderr)
# KAITEN_LOG_FILE=
