# kaiten-mcp configuration (stdio server)

# Kaiten API base URL. You may omit /api/latest — it will be added automatically.
# Example: https://your-domain.kaiten.ru
KAITEN_API_URL=https://your-domain.kaiten.ru/api/latest

# Personal Kaiten API token.
# If unset, the server requests it via MCP elicitation on the first call.
# KAITEN_API_TOKEN=your-token-here

# Optional settings:

# Default space ID for list_boards without an explicit space_id
# KAITEN_DEFAULT_SPACE_ID=

# Kaiten request timeout, ms (default 30000)
# KAITEN_REQUEST_TIMEOUT_MS=30000

# Max concurrent requests, 1–20 (default 5)
# KAITEN_MAX_CONCURRENT_REQUESTS=5

# Log level: error | warn | info | debug (default info)
# KAITEN_LOG_LEVEL=info

# Log file path (default: stderr only)
# KAITEN_LOG_FILE=
