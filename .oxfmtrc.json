{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"semi": false,
	"sortPackageJson": false,
	"ignorePatterns": [
		".claude/**",
		".serena/**",
		"**/dist/**",
		"**/.next/**",
		"**/package-lock.json"
	],
	"overrides": [
		{
			"files": ["**/*.{yml,yaml,md}"],
			"options": { "useTabs": false, "tabWidth": 2 }
		}
	]
}
