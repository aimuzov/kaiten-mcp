# ВАЖНО: KAITEN_API_URL и KAITEN_API_TOKEN НЕ обязательны.
# Если их не задать, сервер спросит их у вас прямо в MCP-клиенте при первом
# обращении к Kaiten (механизм elicitation; нужна поддержка клиентом).
# Токен в этом случае хранится только в памяти на время сессии.

# Базовый URL Kaiten API. Обычно это https://<ваш-домен>.kaiten.ru/api/latest
# Можно указать и без /api/latest — он будет добавлен автоматически.
KAITEN_API_URL=https://your-domain.kaiten.ru/api/latest

# Персональный API-токен Kaiten.
# Получить: Профиль -> Настройки -> API ключи (или /profile в Kaiten).
KAITEN_API_TOKEN=your-api-token-here

# (необязательно) ID пространства по умолчанию для инструментов, где space не указан.
# KAITEN_DEFAULT_SPACE_ID=123456

# (необязательно) Тайм-аут запросов к API, мс. По умолчанию 30000.
# KAITEN_REQUEST_TIMEOUT_MS=30000

# (необязательно) Максимум одновременных запросов к API (1-20). По умолчанию 5.
# KAITEN_MAX_CONCURRENT_REQUESTS=5

# (необязательно) Уровень логирования: error | warn | info | debug. По умолчанию info.
# KAITEN_LOG_LEVEL=info

# (необязательно) Путь к файлу лога. Если не задан — логи идут только в stderr.
# KAITEN_LOG_FILE=/tmp/kaiten-mcp.log
